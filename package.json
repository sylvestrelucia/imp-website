{
  "name": "imp-website",
  "version": "0.1.0",
  "private": true,
  "description": "IMP Website — Built with Next.js, Payload CMS, and Tailwind CSS 4",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=--no-deprecation next build",
    "postbuild": "next-sitemap --config next-sitemap.config.cjs",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "dev:prod": "cross-env NODE_OPTIONS=--no-deprecation rm -rf .next && pnpm build && pnpm start",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation tsc --noEmit",
    "lint:fix": "cross-env NODE_OPTIONS=--no-deprecation tsc --noEmit",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "sync:wix-documents": "tsx scripts/upload-footer-download-assets.ts",
    "import:fund-commentaries": "tsx scripts/import-fund-commentaries.ts",
    "sync:wix-portfolio-charts": "tsx scripts/migrate-portfolio-strategy-chart-data.ts && tsx scripts/set-portfolio-strategy-page-relationships.ts",
    "sync:wix-performance-charts": "tsx scripts/migrate-performance-nav-points.ts && tsx scripts/migrate-performance-share-class-data.ts && cross-env PERFORMANCE_PAGE_SYNC_MODE=charts-only tsx scripts/set-performance-page-label-fields.ts",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "prepare": "husky"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.995.0",
    "@heroicons/react": "^2.2.0",
    "@payloadcms/admin-bar": "^3.79.0",
    "@payloadcms/db-postgres": "^3.79.0",
    "@payloadcms/email-resend": "^3.79.0",
    "@payloadcms/live-preview-react": "^3.79.0",
    "@payloadcms/next": "^3.79.0",
    "@payloadcms/plugin-form-builder": "^3.79.0",
    "@payloadcms/plugin-nested-docs": "^3.79.0",
    "@payloadcms/plugin-redirects": "^3.79.0",
    "@payloadcms/plugin-search": "^3.79.0",
    "@payloadcms/plugin-seo": "^3.79.0",
    "@payloadcms/richtext-lexical": "^3.79.0",
    "@payloadcms/storage-s3": "^3.79.0",
    "@payloadcms/ui": "^3.79.0",
    "@phosphor-icons/react": "^2.1.10",
    "@radix-ui/react-checkbox": "^1.0.4",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-three/fiber": "^9.5.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.7",
    "geist": "^1.3.0",
    "graphql": "^16.8.2",
    "lucide-animated": "^1.0.0",
    "mammoth": "^1.11.0",
    "maplibre-gl": "^5.19.0",
    "motion": "^12.34.4",
    "next": "16.2.0-canary.85",
    "next-sitemap": "^4.2.3",
    "ogl": "^1.0.11",
    "opentype.js": "^1.3.4",
    "payload": "^3.79.0",
    "pdf-parse": "^2.4.5",
    "prism-react-renderer": "^2.3.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.71.0",
    "recharts": "^3.7.0",
    "resend": "^6.9.3",
    "sharp": "0.34.2",
    "svix": "^1.87.0",
    "tailwind-merge": "^3.4.0",
    "three": "^0.167.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/typography": "^0.5.19",
    "@types/escape-html": "^1.0.2",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^9.16.0",
    "eslint-config-next": "16.2.0-canary.85",
    "husky": "^9.1.7",
    "postcss": "^8.4.38",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.9.0",
    "pnpm": "^9 || ^10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "unrs-resolver"
    ]
  }
}
