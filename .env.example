# Supabase PostgreSQL connection string
# Go to Supabase Dashboard > Project Settings > Database > Connection string > URI
# Use the "Transaction" pooler (port 6543) for serverless environments like Vercel
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# Supabase Storage (S3-compatible)
# Go to Supabase Dashboard > Project Settings > Storage > S3 Connection
S3_ENDPOINT=https://[PROJECT-REF].supabase.co/storage/v1/s3
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key
S3_BUCKET=media
S3_REGION=your-region

# Used to encrypt JWT tokens
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Used to configure CORS, format links and more. No trailing slash
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Optional: Google Tag Manager container ID (loaded only after consent)
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Secret used to authenticate cron jobs
CRON_SECRET=YOUR_CRON_SECRET_HERE

# Used to validate preview requests
PREVIEW_SECRET=YOUR_SECRET_HERE

# Wix API credentials (for Wix data import)
# Get these from: https://dev.wix.com/docs/rest/articles/getting-started/api-keys
WIX_API_KEY=YOUR_WIX_API_KEY_HERE
WIX_SITE_ID=YOUR_WIX_SITE_ID_HERE
WIX_ACCOUNT_ID=YOUR_WIX_ACCOUNT_ID_HERE

# Resend email provider (for form emails)
# Get this from: https://resend.com/api-keys
RESEND_API_KEY=YOUR_RESEND_API_KEY_HERE
# Must be a verified sender/domain in Resend
RESEND_FROM_EMAIL=noreply@yourdomain.com
RESEND_FROM_NAME=IMP Website
# Optional absolute URL for the email logo image (PNG recommended for deliverability)
EMAIL_LOGO_URL=https://your-project-ref.supabase.co/storage/v1/object/public/media/email-logo.png
# Optional fallback audience used when no topic-specific mapping is configured
RESEND_CONTACTS_AUDIENCE_ID=aud_your_default_contacts_audience
# Optional topic-to-audience mapping for contact inquiry choices
RESEND_AUDIENCE_ID_GENERAL_INQUIRY=aud_your_general_inquiry_audience
RESEND_AUDIENCE_ID_INVESTMENT_REQUEST=aud_your_investment_request_audience
RESEND_AUDIENCE_ID_REQUEST_FACTSHEET=aud_your_request_factsheet_audience
# Newsletter "General" audience
RESEND_AUDIENCE_ID_NEWSLETTER_GENERAL=aud_your_newsletter_general_audience
# Resend webhook signing secret (from Resend Webhooks settings)
RESEND_WEBHOOK_SIGNING_SECRET=rewhsec_your_webhook_secret_here
